<UserControl
    x:Class="MinecraftLocalizer.Views.Controls.CustomTooltip"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:MinecraftLocalizer.Views.Controls"
    x:Name="Root">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MinecraftLocalizer;component/Styles/ToolTipStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Border
            x:Name="RootBorder"
            Padding="{Binding BadgePadding, ElementName=Root}"
            Background="{Binding BadgeBackground, ElementName=Root}"
            CornerRadius="{Binding BadgeCornerRadius, ElementName=Root}">
            <Label
                Padding="{Binding BadgeLabelPadding, ElementName=Root}"
                Content="{Binding BadgeContent, ElementName=Root}"
                FontSize="{Binding BadgeFontSize, ElementName=Root}"
                FontWeight="{Binding BadgeFontWeight, ElementName=Root}"
                Style="{StaticResource TooltipStyle}" />
        </Border>

        <Popup
            x:Name="TooltipPopup"
            AllowsTransparency="True"
            IsHitTestVisible="True"
            IsOpen="False"
            Placement="Bottom"
            PlacementTarget="{Binding ElementName=RootBorder}"
            PopupAnimation="Fade"
            StaysOpen="True"
            VerticalOffset="6">
            <Border
                MaxWidth="260"
                Padding="10"
                Background="#333"
                CornerRadius="5">
                <ContentPresenter x:Name="TooltipPresenter" />
            </Border>
        </Popup>
    </Grid>
</UserControl>
